{
    "name": "@rtcforge/core",
    "version": "0.1.0",
    "description": "Shared primitives — EventEmitter, Logger",
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": ["dist"],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean --target es2020",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch --target es2020",
        "typecheck": "tsc --noEmit"
    },
    "keywords": ["rtcforge"],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    }
}
