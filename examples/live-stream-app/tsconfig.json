{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "paths": {
            "@rtcforge/core": ["../../packages/core/src/index.ts"],
            "@rtcforge/sdk": ["../../packages/sdk/src/index.ts"],
            "@rtcforge/signaling": ["../../packages/signaling/src/index.ts"],
            "@rtcforge/media": ["../../packages/media/src/index.ts"]
        }
    },
    "include": ["src", "server.ts", "vite.config.ts"]
}
