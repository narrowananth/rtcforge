{
    "name": "@rtcforge/streaming",
    "version": "0.1.0",
    "description": "StreamingService \u2014 HLS/RTMP egress pipeline",
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": ["dist"],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
        "typecheck": "tsc --noEmit"
    },
    "keywords": ["streaming", "hls", "rtmp", "webrtc", "rtcforge"],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    }
}
