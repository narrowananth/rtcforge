{
    "name": "rtcforge-core",
    "version": "0.1.1",
    "description": "Shared primitives — EventEmitter, Logger",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean --target es2020"
    },
    "keywords": ["rtcforge"],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    }
}
