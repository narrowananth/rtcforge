{
    "name": "rtcforge-signaling",
    "version": "1.0.1",
    "private": true,
    "description": "Internal to rtcforge — install `rtcforge` instead. Signaling server (SignalingServer, Room, Peer, auth hook).",
    "homepage": "https://narrowananth.github.io/rtcforge/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/narrowananth/rtcforge.git",
        "directory": "packages/signaling"
    },
    "bugs": {
        "url": "https://github.com/narrowananth/rtcforge/issues"
    },
    "author": "narrowananth",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "sideEffects": false,
    "files": ["dist", "LICENSE"],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean",
        "test": "vitest run"
    },
    "keywords": ["webrtc", "signaling", "realtime", "rtcforge"],
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "rtcforge-core": "^1.0.1",
        "ws": "^8.20.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/ws": "^8.18.1"
    }
}
