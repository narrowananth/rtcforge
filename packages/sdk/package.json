{
    "name": "rtcforge-sdk",
    "version": "2.0.0",
    "private": true,
    "description": "Internal to rtcforge — install `rtcforge` instead. Browser + Node.js client (RTCForgeClient, Room, file transfer).",
    "homepage": "https://narrowananth.github.io/rtcforge/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/narrowananth/rtcforge.git",
        "directory": "packages/sdk"
    },
    "bugs": {
        "url": "https://github.com/narrowananth/rtcforge/issues"
    },
    "author": "narrowananth",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./filetransfer": {
            "types": "./dist/filetransfer/index.d.ts",
            "import": "./dist/filetransfer/index.mjs",
            "require": "./dist/filetransfer/index.js"
        },
        "./filetransfer/node": {
            "types": "./dist/filetransfer/node/index.d.ts",
            "import": "./dist/filetransfer/node/index.mjs",
            "require": "./dist/filetransfer/node/index.js"
        }
    },
    "sideEffects": false,
    "files": ["dist", "LICENSE"],
    "scripts": {
        "build": "tsup src/index.ts src/filetransfer/index.ts src/filetransfer/node/index.ts --format cjs,esm --dts --clean --target es2020",
        "test": "vitest run"
    },
    "keywords": ["webrtc", "sdk", "browser", "realtime", "rtcforge"],
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "rtcforge-core": "^2.0.0",
        "zod": "^4.4.3"
    },
    "optionalDependencies": {
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@types/ws": "^8.5.12"
    }
}
