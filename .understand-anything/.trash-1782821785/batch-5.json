            "name": "Clock.ts",
            "filePath": "packages/core/src/Clock.ts",
            "summary": "Defines the Clock abstraction used throughout @rtcforge/core for time and timer access, providing the real systemClock and a deterministic ManualClock for testing time-dependent logic.",
            "tags": ["abstraction", "time", "test-utility", "type-definition"],
            "complexity": "simple",
            "languageNotes": "Dependency-injectable clock pattern lets every primitive (membership, locks, state store) be tested deterministically by advancing a ManualClock."
        },
        {
            "id": "class:packages/core/src/Clock.ts:ManualClock",
            "type": "class",
            "name": "ManualClock",
            "filePath": "packages/core/src/Clock.ts",
            "lineRange": [19, 56],
            "summary": "Deterministic Clock implementation whose now() only advances via advance(), draining due scheduled timers in fire order so timing-sensitive code can be unit tested without real delays.",
            "tags": ["test-utility", "time", "scheduler", "fake"],
            "complexity": "simple"
        },
        {
            "id": "file:packages/core/src/Gossip.ts",
            "type": "file",
            "name": "Gossip.ts",
            "filePath": "packages/core/src/Gossip.ts",
            "summary": "Implements an epidemic gossip-based cluster membership protocol with incarnation numbers, alive/dead/tombstone lifecycle, and a fanout-limited transport, enabling multi-node RTCForge deployments to discover and track peers without a central registry.",
            "tags": ["distributed-systems", "membership", "gossip", "clustering", "service"],
            "complexity": "complex",
            "languageNotes": "SWIM-style gossip: incarnation numbers resolve conflicting state, periodic ticks gossip a digest to a random subset of peers, and dead members are swept after deadTimeoutMs then garbage-collected after tombstoneMs."
        },
