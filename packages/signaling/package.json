{
    "name": "rtcforge-signaling",
    "version": "0.1.1",
    "description": "SignalingServer, Room, Peer — session lifecycle and auth hook",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean"
    },
    "keywords": ["webrtc", "signaling", "realtime", "rtcforge"],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "rtcforge-core": "^0.1.0",
        "ws": "^8.20.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/ws": "^8.18.1"
    }
}
