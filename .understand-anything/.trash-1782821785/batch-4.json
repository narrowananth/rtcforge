            "type": "file",
            "name": "JoinHandshake.ts",
            "filePath": "packages/sdk/src/JoinHandshake.ts",
            "summary": "Drives the one-shot connect-and-join handshake: connects the transport, waits for the server's joined message (or a timeout), and resolves or rejects accordingly.",
