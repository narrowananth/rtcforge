{
    "name": "rtcforge-core",
    "version": "1.0.1",
    "private": true,
    "description": "Internal to rtcforge — install `rtcforge` instead. Zero-dependency primitives (EventEmitter, Logger, HashRing, gossip membership).",
    "homepage": "https://narrowananth.github.io/rtcforge/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/narrowananth/rtcforge.git",
        "directory": "packages/core"
    },
    "bugs": {
        "url": "https://github.com/narrowananth/rtcforge/issues"
    },
    "author": "narrowananth",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "sideEffects": false,
    "files": ["dist", "LICENSE"],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean --target es2020",
        "test": "vitest run"
    },
    "keywords": ["rtcforge", "webrtc", "gossip", "hashring"],
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
