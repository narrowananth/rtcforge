{
    "name": "rtcforge-sfu",
    "version": "0.1.2",
    "description": "Cascading SFU cluster management — multi-node routing, load balancing, bandwidth estimation",
    "homepage": "https://narrowananth.github.io/rtcforge/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/narrowananth/rtcforge.git",
        "directory": "packages/sfu"
    },
    "bugs": {
        "url": "https://github.com/narrowananth/rtcforge/issues"
    },
    "author": "narrowananth",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean"
    },
    "keywords": ["sfu", "webrtc", "cascading", "cluster", "rtcforge"],
    "license": "MIT",
    "dependencies": {
        "rtcforge-core": "^0.1.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
