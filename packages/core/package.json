{
    "name": "rtcforge-core",
    "version": "0.1.2",
    "description": "Shared primitives — EventEmitter, Logger",
    "homepage": "https://narrowananth.github.io/rtcforge/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/narrowananth/rtcforge.git",
        "directory": "packages/core"
    },
    "bugs": {
