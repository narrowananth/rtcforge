{
    "name": "@rtcforge/sfu",
    "version": "0.1.0",
    "description": "Cascading SFU cluster management \u2014 multi-node routing, load balancing, bandwidth estimation",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean"
    },
    "keywords": ["sfu", "webrtc", "cascading", "cluster", "rtcforge"],
    "license": "MIT",
    "dependencies": {
        "@rtcforge/core": "^0.1.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
