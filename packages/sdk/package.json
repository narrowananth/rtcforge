{
    "name": "@rtcforge/sdk",
    "version": "0.1.0",
    "description": "Browser + Node.js client SDK — RTCForgeClient",
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "files": ["dist"],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean --target es2020",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch --target es2020",
        "typecheck": "tsc --noEmit"
    },
    "keywords": ["webrtc", "sdk", "browser", "realtime", "rtcforge"],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    }
}
