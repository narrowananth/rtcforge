{
    "name": "rtcforge-adapter-udp",
    "version": "1.0.0",
    "description": "DEPRECATED — folded into rtcforge-sfu. Use `rtcforge-sfu/udp`. Thin re-export kept for backwards compatibility.",
    "deprecated": "rtcforge-adapter-udp has moved into rtcforge-sfu. Install rtcforge-sfu and import from 'rtcforge-sfu/udp'.",
    "homepage": "https://narrowananth.github.io/rtcforge/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/narrowananth/rtcforge.git",
        "directory": "packages/adapter-udp"
    },
    "bugs": {
        "url": "https://github.com/narrowananth/rtcforge/issues"
    },
    "author": "narrowananth",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "sideEffects": false,
    "files": ["dist", "LICENSE"],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean --external rtcforge-sfu"
    },
    "keywords": ["gossip", "swim", "udp", "cluster", "rtcforge", "deprecated"],
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "rtcforge-sfu": "^1.0.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
