{
    "name": "rtcforge",
    "version": "1.1.0",
    "description": "One-install front door for RTCForge — real-time WebRTC infrastructure. Frontend via rtcforge/client + rtcforge/media, backend via rtcforge/server.",
    "homepage": "https://narrowananth.github.io/rtcforge/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/narrowananth/rtcforge.git",
        "directory": "packages/rtcforge"
    },
    "bugs": {
        "url": "https://github.com/narrowananth/rtcforge/issues"
    },
    "author": "narrowananth",
    "sideEffects": false,
    "exports": {
        "./core": {
            "types": "./dist/core.d.ts",
            "import": "./dist/core.mjs",
            "require": "./dist/core.cjs"
        },
        "./client": {
            "types": "./dist/client.d.ts",
            "import": "./dist/client.mjs",
            "require": "./dist/client.cjs"
        },
        "./server": {
            "types": "./dist/server.d.ts",
            "import": "./dist/server.mjs",
            "require": "./dist/server.cjs"
        },
        "./media": {
            "browser": {
                "types": "./dist/media.browser.d.ts",
                "import": "./dist/media.browser.mjs",
                "require": "./dist/media.browser.cjs"
            },
            "types": "./dist/media.d.ts",
            "import": "./dist/media.mjs",
            "require": "./dist/media.cjs"
        },
        "./filetransfer": {
            "types": "./dist/filetransfer.d.ts",
            "import": "./dist/filetransfer.mjs",
            "require": "./dist/filetransfer.cjs"
        },
        "./filetransfer/node": {
            "types": "./dist/filetransfer/node.d.ts",
            "import": "./dist/filetransfer/node.mjs",
            "require": "./dist/filetransfer/node.cjs"
        },
        "./sfu": {
            "types": "./dist/sfu.d.ts",
            "import": "./dist/sfu.mjs",
            "require": "./dist/sfu.cjs"
        },
        "./sfu/udp": {
            "types": "./dist/sfu/udp.d.ts",
            "import": "./dist/sfu/udp.mjs",
            "require": "./dist/sfu/udp.cjs"
        }
    },
    "files": ["dist", "LICENSE", "README.md"],
    "keywords": ["webrtc", "realtime", "sfu", "signaling", "rtcforge"],
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build": "tsup"
    },
    "dependencies": {
        "ws": "^8.20.1",
        "zod": "^4.4.3"
    },
    "peerDependencies": {
        "mediasoup": "^3.20.10"
    },
    "peerDependenciesMeta": {
        "mediasoup": {
            "optional": true
        }
    },
    "devDependencies": {
        "rtcforge-core": "^1.0.1",
        "rtcforge-sdk": "^1.0.1",
        "rtcforge-signaling": "^1.0.1",
        "rtcforge-media": "^1.0.1",
        "rtcforge-sfu": "^1.0.1"
    },
    "publishConfig": {
        "access": "public"
    }
}
