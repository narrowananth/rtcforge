{
    "name": "rtcforge-media",
    "version": "0.1.2",
    "description": "WebRTC peer connections, media capture, and call management",
    "homepage": "https://narrowananth.github.io/rtcforge/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/narrowananth/rtcforge.git",
        "directory": "packages/media"
    },
    "bugs": {
        "url": "https://github.com/narrowananth/rtcforge/issues"
    },
    "author": "narrowananth",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "browser": "./dist/browser.mjs",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./browser": {
            "types": "./dist/browser.d.ts",
            "import": "./dist/browser.mjs",
            "require": "./dist/browser.js"
        }
    },
    "browser": "./dist/browser.mjs",
    "files": ["dist"],
    "scripts": {
        "build": "tsup src/index.ts src/browser.ts --format cjs,esm --dts --clean"
    },
    "keywords": ["webrtc", "mediasoup", "sfu", "realtime", "rtcforge"],
    "license": "MIT",
    "dependencies": {
        "mediasoup": "^3.20.10",
        "zod": "^4.4.3"
    },
    "peerDependencies": {
        "rtcforge-core": "^0.1.0",
        "rtcforge-sdk": "^0.1.0",
        "rtcforge-signaling": "^0.1.0"
    },
    "devDependencies": {
        "rtcforge-core": "^0.1.0",
        "rtcforge-sdk": "^0.1.0",
        "rtcforge-signaling": "^0.1.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
