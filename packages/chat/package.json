{
    "name": "@rtcforge/chat",
    "version": "0.1.0",
    "description": "ChatService, PresenceService, typing indicators",
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": ["dist"],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "keywords": ["chat", "presence", "realtime", "rtcforge"],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "@rtcforge/signaling": ">=0.1.0"
    }
}
