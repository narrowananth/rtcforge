            "name": "RTCForgeClient.ts",
            "filePath": "packages/sdk/src/RTCForgeClient.ts",
            "summary": "Top-level SDK client developers instantiate to connect to an RTCForge signaling server, join a room, manage connection-state transitions, and leave cleanly.",
            "tags": ["entry-point", "api-handler", "client", "state-machine", "event-handler"],
            "complexity": "complex",
            "languageNotes": "Connection lifecycle is guarded by a LEGAL_TRANSITIONS state-machine table and a cleanup-callback stack."
        },
        {
