{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "noEmit": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "paths": {
            "rtcforge-core": ["./packages/core/src/index.ts"],
            "rtcforge-signaling": ["./packages/signaling/src/index.ts"],
            "rtcforge-sdk": ["./packages/sdk/src/index.ts"],
            "rtcforge-sdk/filetransfer": ["./packages/sdk/src/filetransfer/index.ts"],
            "rtcforge-media": ["./packages/media/src/index.ts"],
            "rtcforge-sfu": ["./packages/sfu/src/index.ts"],
            "rtcforge-sfu/udp": ["./packages/sfu/src/udp.ts"]
        }
    },
    "include": ["packages/*/src/**/*.ts", "packages/*/tests/**/*.ts"]
}
