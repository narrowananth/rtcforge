{
    "name": "rtcforge",
    "version": "0.1.2",
    "private": true,
    "type": "module",
    "description": "Build real-time applications without reinventing infrastructure",
    "workspaces": ["packages/*"],
    "scripts": {
        "build": "npm run build --workspaces --if-present",
        "dev": "npm run dev --workspaces --if-present",
        "typecheck": "tsc --noEmit",
        "check": "biome check .",
        "check:fix": "biome check --write .",
        "clean": "rimraf packages/*/dist",
        "test": "vitest run",
        "test:e2e": "playwright test -c e2e/playwright.config.ts",
        "docs": "typedoc",
        "changeset": "changeset",
        "version-packages": "changeset version",
        "release": "npm run build && changeset publish",
        "prepare": "husky"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9",
        "@changesets/cli": "^2.27.0",
        "@playwright/test": "^1.48.0",
        "@types/node": "^20.19.41",
        "esbuild": "^0.24.0",
        "husky": "^9",
        "lint-staged": "^15",
        "pngjs": "^7.0.0",
        "rimraf": "^6",
        "tsup": "^8",
        "typedoc": "^0.28.19",
        "typescript": "^5",
        "vitest": "^2"
    },
    "lint-staged": {
        "**/*.{ts,tsx,js,jsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
