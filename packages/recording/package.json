{
    "name": "@rtcforge/recording",
    "version": "0.1.0",
    "description": "RecordingService \u2014 per-room recording handles, S3/MinIO upload",
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": ["dist"],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
        "typecheck": "tsc --noEmit"
    },
    "keywords": ["recording", "ffmpeg", "s3", "realtime", "rtcforge"],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    }
}
