{
    "name": "rtcforge-sfu",
    "version": "1.0.1",
    "private": true,
    "description": "Internal to rtcforge — install `rtcforge` instead. Cascading SFU cluster (multi-node routing, load balancing).",
    "homepage": "https://narrowananth.github.io/rtcforge/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/narrowananth/rtcforge.git",
        "directory": "packages/sfu"
    },
    "bugs": {
        "url": "https://github.com/narrowananth/rtcforge/issues"
    },
    "author": "narrowananth",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        },
        "./udp": {
            "import": {
                "types": "./dist/udp.d.mts",
                "default": "./dist/udp.mjs"
            },
            "require": {
                "types": "./dist/udp.d.ts",
                "default": "./dist/udp.js"
            }
        }
    },
    "sideEffects": false,
    "files": ["dist", "LICENSE"],
    "scripts": {
        "build": "tsup src/index.ts src/udp.ts --format cjs,esm --dts --clean",
        "test": "vitest run"
    },
    "keywords": ["sfu", "webrtc", "cascading", "cluster", "gossip", "udp", "rtcforge"],
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "rtcforge-core": "^1.0.1"
    },
    "publishConfig": {
        "access": "public"
    }
}
