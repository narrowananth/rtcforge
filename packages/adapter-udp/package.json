{
    "name": "@rtcforge/adapter-udp",
    "version": "0.1.0",
    "description": "UDP GossipTransport adapter — connectionless wire for @rtcforge/core GossipMembership",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean"
    },
    "keywords": ["gossip", "swim", "udp", "cluster", "rtcforge"],
    "license": "MIT",
    "dependencies": {
        "@rtcforge/core": "*"
    },
    "publishConfig": {
        "access": "public"
    }
}
