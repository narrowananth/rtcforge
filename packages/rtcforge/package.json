{
    "name": "rtcforge",
    "version": "1.1.0",
    "description": "One-install front door for RTCForge — real-time WebRTC infrastructure. Frontend via rtcforge/client + rtcforge/media, backend via rtcforge/server.",
    "homepage": "https://narrowananth.github.io/rtcforge/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/narrowananth/rtcforge.git",
        "directory": "packages/rtcforge"
    },
    "bugs": {
        "url": "https://github.com/narrowananth/rtcforge/issues"
    },
    "author": "narrowananth",
    "sideEffects": false,
    "exports": {
        "./core": {
            "import": { "types": "./dist/core.d.mts", "default": "./dist/core.mjs" },
            "require": { "types": "./dist/core.d.ts", "default": "./dist/core.cjs" }
        },
        "./client": {
            "import": { "types": "./dist/client.d.mts", "default": "./dist/client.mjs" },
            "require": { "types": "./dist/client.d.ts", "default": "./dist/client.cjs" }
        },
        "./server": {
            "import": { "types": "./dist/server.d.mts", "default": "./dist/server.mjs" },
            "require": { "types": "./dist/server.d.ts", "default": "./dist/server.cjs" }
        },
        "./media": {
            "browser": {
                "import": {
                    "types": "./dist/media.browser.d.mts",
                    "default": "./dist/media.browser.mjs"
                },
                "require": {
                    "types": "./dist/media.browser.d.ts",
                    "default": "./dist/media.browser.cjs"
                }
            },
            "import": { "types": "./dist/media.d.mts", "default": "./dist/media.mjs" },
            "require": { "types": "./dist/media.d.ts", "default": "./dist/media.cjs" }
        },
        "./filetransfer": {
            "import": {
                "types": "./dist/filetransfer.d.mts",
                "default": "./dist/filetransfer.mjs"
            },
            "require": { "types": "./dist/filetransfer.d.ts", "default": "./dist/filetransfer.cjs" }
        },
        "./filetransfer/node": {
            "import": {
                "types": "./dist/filetransfer/node.d.mts",
                "default": "./dist/filetransfer/node.mjs"
            },
            "require": {
                "types": "./dist/filetransfer/node.d.ts",
                "default": "./dist/filetransfer/node.cjs"
            }
        },
        "./sfu": {
            "import": { "types": "./dist/sfu.d.mts", "default": "./dist/sfu.mjs" },
            "require": { "types": "./dist/sfu.d.ts", "default": "./dist/sfu.cjs" }
        },
        "./sfu/udp": {
            "import": { "types": "./dist/sfu/udp.d.mts", "default": "./dist/sfu/udp.mjs" },
            "require": { "types": "./dist/sfu/udp.d.ts", "default": "./dist/sfu/udp.cjs" }
        }
    },
    "files": ["dist", "LICENSE", "README.md", "CHANGELOG.md"],
    "keywords": ["webrtc", "realtime", "sfu", "signaling", "rtcforge"],
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build": "tsup"
    },
    "dependencies": {
        "ws": "^8.20.1",
        "zod": "^4.4.3"
    },
    "peerDependencies": {
        "mediasoup": "^3.20.10"
    },
    "peerDependenciesMeta": {
        "mediasoup": {
            "optional": true
        }
    },
    "devDependencies": {
        "rtcforge-core": "^1.0.1",
        "rtcforge-sdk": "^1.0.1",
        "rtcforge-signaling": "^1.0.1",
        "rtcforge-media": "^1.0.1",
        "rtcforge-sfu": "^1.0.1"
    },
    "publishConfig": {
        "access": "public"
    }
}
