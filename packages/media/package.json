{
    "name": "rtcforge-media",
    "version": "1.0.1",
    "private": true,
    "description": "Internal to rtcforge — install `rtcforge` instead. WebRTC peer connections, media capture, and calls.",
    "homepage": "https://narrowananth.github.io/rtcforge/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/narrowananth/rtcforge.git",
        "directory": "packages/media"
    },
    "bugs": {
        "url": "https://github.com/narrowananth/rtcforge/issues"
    },
    "author": "narrowananth",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "browser": {
                "types": "./dist/browser.d.mts",
                "default": "./dist/browser.mjs"
            },
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        },
        "./browser": {
            "import": {
                "types": "./dist/browser.d.mts",
                "default": "./dist/browser.mjs"
            },
            "require": {
                "types": "./dist/browser.d.ts",
                "default": "./dist/browser.js"
            }
        }
    },
    "browser": "./dist/browser.mjs",
    "sideEffects": false,
    "files": ["dist", "LICENSE"],
    "scripts": {
        "build": "tsup src/index.ts src/browser.ts --format cjs,esm --dts --clean"
    },
    "keywords": ["webrtc", "mediasoup", "sfu", "realtime", "rtcforge"],
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "rtcforge-core": "^1.0.1",
        "rtcforge-sdk": "^1.0.1",
        "zod": "^4.4.3"
    },
    "peerDependencies": {
        "mediasoup": "^3.20.10",
        "rtcforge-signaling": "^1.0.1"
    },
    "peerDependenciesMeta": {
        "mediasoup": {
            "optional": true
        },
        "rtcforge-signaling": {
            "optional": true
        }
    },
    "devDependencies": {
        "mediasoup": "^3.20.10",
        "rtcforge-signaling": "^1.0.1"
    },
    "publishConfig": {
        "access": "public"
    }
}
