{
    "name": "rtcforge-sdk",
    "version": "0.1.0",
    "description": "Browser + Node.js client SDK \u2014 RTCForgeClient",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean --target es2020"
    },
    "keywords": ["webrtc", "sdk", "browser", "realtime", "rtcforge"],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "rtcforge-core": "^0.1.0",
        "zod": "^4.4.3"
    },
    "optionalDependencies": {
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@types/ws": "^8.5.12"
    }
}
